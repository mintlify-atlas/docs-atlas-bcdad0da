  "keyFeatures": [
    "Self-hosted ebook and comic management",
    "Web-based reader with EPUB and PDF support",
    "Automatic metadata fetching from OpenLibrary and Google Books",
    "User authentication with JWT and invitation system",
    "Reading progress tracking across devices",
    "Automatic library scanning and organization",
    "Role-based permissions and admin panel",
    "Cover art management with automatic downloads"
  ],
  "publicApiSurface": [
    "GET /books - List all books with authors",
    "GET /books/:id - Get book details",
    "GET /books/:id/stream - Stream book content",
    "GET /covers/:id - Get book cover image",
    "GET /books/authors - List all authors",
    "GET /books/authors/:id - Get author with books",
    "GET /books/:id/progress - Get reading progress",
    "PUT /books/:id/progress - Update reading progress",
    "GET /reading/currently-reading - Get currently reading books",
    "GET /reading/completed - Get completed books",
    "GET /tags - List all tags",
    "POST /books/:id/tags - Add tag to book",
    "DELETE /books/:id/tags/:tagName - Remove tag from book",
    "POST /auth/register - Register new user",
    "POST /auth/login - Login user",
    "POST /auth/logout - Logout user",
    "GET /users/me - Get current user profile",
    "GET /admin/users - List all users (admin)",
    "POST /admin/scan - Trigger library scan (admin)",
    "POST /admin/books/:id/refresh-metadata - Refresh book metadata (admin)"
  ]
